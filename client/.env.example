# Base URL of the deployed BugTrack API, INCLUDING the /api suffix.
# Vite inlines this at build time, so it must be set in Vercel project settings
# (Environment Variables) before the frontend build runs.
# Local dev can leave this unset — it defaults to http://localhost:5000/api.
VITE_API_URL=https://your-backend-project.vercel.app/api
