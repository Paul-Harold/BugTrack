# Local dev: a running MongoDB instance. Production (Vercel): a MongoDB Atlas
# connection string, e.g. mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/bugtrack
MONGO_URI=mongodb://localhost:27017/bugtrack

# Long random string used to sign JWTs. Generate one for production.
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Allowed frontend origin(s) for CORS. Single URL or comma-separated list.
# Leave unset to allow any origin (safe here — auth is Bearer-token, not cookies).
CLIENT_URL=http://localhost:5173

# Only used by the local server (npm run dev). Vercel sets the port itself.
PORT=5000
